{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Bounteous base design system — the organisation's one set of chosen values. Every component reads from this tier. Change values here to retheme the entire system.",

  "action": {
    "primary": {
      "bg":               { "$value": "{color.primary.default}",   "$type": "color",     "$description": "Button / CTA background" },
      "bg-hover":         { "$value": "{color.primary.hover}",     "$type": "color",     "$description": "Button / CTA background — hovered" },
      "bg-active":        { "$value": "{color.primary.active}",    "$type": "color",     "$description": "Button / CTA background — pressed" },
      "bg-disabled":      { "$value": "{color.disabled.surface}",  "$type": "color",     "$description": "Button / CTA background — disabled" },
      "text":             { "$value": "{color.text.on-primary}",   "$type": "color",     "$description": "Button / CTA label colour" },
      "text-disabled":    { "$value": "{color.disabled.text}",     "$type": "color",     "$description": "Button / CTA label — disabled" },
      "border":           { "$value": "{color.primary.default}",   "$type": "color",     "$description": "Button / CTA border" },
      "border-disabled":  { "$value": "{color.disabled.border}",   "$type": "color",     "$description": "Button / CTA border — disabled" },
      "radius":           { "$value": "{corner.default}",          "$type": "dimension", "$description": "Button corner radius" },
      "padding-x-sm":     { "$value": "{space.component.padding-xs}", "$type": "dimension", "$description": "Button horizontal padding — SM size" },
      "padding-y-sm":     { "$value": "{space.component.padding-xs}", "$type": "dimension", "$description": "Button vertical padding — SM size" },
      "padding-x-md":     { "$value": "{space.component.padding-md}", "$type": "dimension", "$description": "Button horizontal padding — MD size" },
      "padding-y-md":     { "$value": "{space.component.padding-sm}", "$type": "dimension", "$description": "Button vertical padding — MD size" },
      "padding-x-lg":     { "$value": "{space.component.padding-lg}", "$type": "dimension", "$description": "Button horizontal padding — LG size" },
      "padding-y-lg":     { "$value": "{space.component.padding-md}", "$type": "dimension", "$description": "Button vertical padding — LG size" },
      "icon-gap":         { "$value": "{space.component.gap-xs}",  "$type": "dimension", "$description": "Gap between icon and label" },
      "font-family":      { "$value": "{font.family.primary}",     "$type": "fontFamily","$description": "Button font family" },
      "font-size-sm":     { "$value": "{font.size.sm}",            "$type": "dimension", "$description": "Button font size — SM" },
      "font-size-md":     { "$value": "{font.size.md}",            "$type": "dimension", "$description": "Button font size — MD" },
      "font-size-lg":     { "$value": "{font.size.lg}",            "$type": "dimension", "$description": "Button font size — LG" },
      "font-weight":      { "$value": "{font.weight.semibold}",    "$type": "fontWeight","$description": "Button font weight" },
      "letter-spacing":   { "$value": "{font.letterspacing.wide}", "$type": "dimension", "$description": "Button label letter spacing" },
      "transition-duration": { "$value": "{motion.duration.fast}", "$type": "duration",  "$description": "Button state transition" },
      "transition-easing":   { "$value": "{motion.easing.ease-out}", "$type": "cubicBezier", "$description": "Button state easing" }
    },
    "secondary": {
      "bg":              { "$value": "{color.secondary.default}",    "$type": "color", "$description": "Secondary button background" },
      "bg-hover":        { "$value": "{color.secondary.hover}",      "$type": "color" },
      "bg-active":       { "$value": "{color.secondary.active}",     "$type": "color" },
      "text":            { "$value": "{color.secondary.on-secondary}", "$type": "color" },
      "border":          { "$value": "{color.border.default}",       "$type": "color" },
      "radius":          { "$value": "{corner.default}",             "$type": "dimension" }
    },
    "ghost": {
      "bg":              { "$value": "transparent",              "$type": "color", "$description": "Ghost button — no background" },
      "bg-hover":        { "$value": "{color.primary.subtle}",   "$type": "color" },
      "text":            { "$value": "{color.primary.default}",  "$type": "color" },
      "border":          { "$value": "transparent",              "$type": "color" },
      "radius":          { "$value": "{corner.default}",         "$type": "dimension" }
    },
    "destructive": {
      "bg":              { "$value": "{color.feedback.error}",       "$type": "color", "$description": "Destructive action background" },
      "bg-hover":        { "$value": "{color.red.700}",              "$type": "color" },
      "text":            { "$value": "{color.white.0}",              "$type": "color" },
      "border":          { "$value": "{color.feedback.error}",       "$type": "color" },
      "radius":          { "$value": "{corner.default}",             "$type": "dimension" }
    }
  },

  "form": {
    "field": {
      "bg":              { "$value": "{color.surface.default}",   "$type": "color",     "$description": "Input field background" },
      "bg-disabled":     { "$value": "{color.disabled.surface}",  "$type": "color" },
      "border":          { "$value": "{color.border.default}",    "$type": "color",     "$description": "Input border — default" },
      "border-hover":    { "$value": "{color.border.strong}",     "$type": "color" },
      "border-focus":    { "$value": "{color.border.focus}",      "$type": "color",     "$description": "Input border — keyboard focus" },
      "border-error":    { "$value": "{color.feedback.error}",    "$type": "color" },
      "border-success":  { "$value": "{color.feedback.success}",  "$type": "color" },
      "border-width":    { "$value": "{border.default.width}",    "$type": "dimension" },
      "focus-ring-width":{ "$value": "{border.focus.width}",      "$type": "dimension" },
      "focus-ring-offset":{ "$value": "2px",                      "$type": "dimension" },
      "text":            { "$value": "{color.text.primary}",      "$type": "color" },
      "placeholder":     { "$value": "{color.text.secondary}",    "$type": "color" },
      "label":           { "$value": "{color.text.primary}",      "$type": "color" },
      "helper":          { "$value": "{color.text.secondary}",    "$type": "color" },
      "radius":          { "$value": "{corner.subtle}",           "$type": "dimension", "$description": "Input corner radius" },
      "padding-x":       { "$value": "{space.component.padding-md}", "$type": "dimension" },
      "padding-y-sm":    { "$value": "{space.component.padding-xs}", "$type": "dimension" },
      "padding-y-md":    { "$value": "{space.component.padding-sm}", "$type": "dimension" }
    }
  },

  "surface": {
    "page":    { "$value": "{color.background.default}",  "$type": "color", "$description": "Page background" },
    "card":    { "$value": "{color.surface.default}",     "$type": "color", "$description": "Card surface" },
    "panel":   { "$value": "{color.surface.raised}",      "$type": "color", "$description": "Panel / sidebar surface" },
    "overlay": { "$value": "{color.overlay.default}",     "$type": "color", "$description": "Scrim behind modals and drawers" }
  },

  "content": {
    "text-primary":   { "$value": "{color.text.primary}",   "$type": "color" },
    "text-secondary": { "$value": "{color.text.secondary}", "$type": "color" },
    "text-disabled":  { "$value": "{color.text.disabled}",  "$type": "color" },
    "text-inverse":   { "$value": "{color.text.inverse}",   "$type": "color" },
    "link":           { "$value": "{color.link.default}",   "$type": "color" },
    "link-hover":     { "$value": "{color.link.hover}",     "$type": "color" }
  },

  "feedback": {
    "success":        { "$value": "{color.feedback.success}",        "$type": "color" },
    "success-subtle": { "$value": "{color.feedback.success-subtle}", "$type": "color" },
    "warning":        { "$value": "{color.feedback.warning}",        "$type": "color" },
    "warning-subtle": { "$value": "{color.feedback.warning-subtle}", "$type": "color" },
    "error":          { "$value": "{color.feedback.error}",          "$type": "color" },
    "error-subtle":   { "$value": "{color.feedback.error-subtle}",   "$type": "color" },
    "info":           { "$value": "{color.feedback.info}",           "$type": "color" },
    "info-subtle":    { "$value": "{color.feedback.info-subtle}",    "$type": "color" }
  },

  "focus": {
    "ring-color":  { "$value": "{color.border.focus}",   "$type": "color",     "$description": "Keyboard focus ring color — meets WCAG 3:1 against all surfaces" },
    "ring-width":  { "$value": "{border.focus.width}",   "$type": "dimension", "$description": "Focus ring width" },
    "ring-offset": { "$value": "2px",                    "$type": "dimension", "$description": "Focus ring offset from element edge" }
  }
}
